{
  "name": "mintflow-backend",
  "version": "1.0.0",
  "description": "Production-ready gasless ERC-4337 Account Abstraction NFT minting backend for MintFlow",
  "main": "dist/app.js",
  "scripts": {
    "build": "rimraf dist && tsc",
    "start": "node dist/app.js",
    "start:worker": "node dist/workerServer.js",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/workerServer.ts",
    "lint": "eslint src/**/*.ts",
    "deploy:badge": "ts-node-dev --transpile-only src/blockchain/compileAndDeploy.ts"
  },
  "dependencies": {
    "bullmq": "^5.8.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^12.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "permissionless": "^0.1.29",
    "rate-limit-redis": "^5.0.0",
    "siwe": "^2.3.2",
    "viem": "^2.13.10",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "rimraf": "^5.0.7",
    "solc": "^0.8.20",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
